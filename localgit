#!/usr/bin/env bash
# vim: ts=8 sts=4 sw=4 et ft=sh

# Copyright (c) 2016-2025, Nicolas Thery (nthery@gmail.com)
#
# Maintain local git branches over sources managed with another SCM.
# See https://github.com/nthery/localgit for details.

# Bail out early if a command exits abnormally.
set -e

progname=$(basename "$0")

commands=""

##############################################################################
# DEBUGGING
##############################################################################

# TODO: Disable when thoroughly tested.
debug=1

# Enable shell tracing if debug mode set.
tron()
{
    if (( debug > 0 )); then
        set -x
    fi
}

# Disable shell tracing if debug mode set.
troff()
{
    if (( debug > 0 )); then
        set +x
    fi
}

##############################################################################
# ERROR MANAGEMENT
##############################################################################

error()
{
    echo 1>&2 "$progname: $*"
    exit 1
}

usage()
{
    local code=0
    if [[ -n "$*" ]]; then
        echo -e 1>&2 "$progname: $*\n"
        code=1
    fi
    echo -e 1>&2 "usage: $progname cmd args\n"
    echo -e 1>&2 "The supported commands are:\n"
    echo -e 1>&2 "$commands"
    exit $code
}

##############################################################################
# HELPERS
##############################################################################

# Keep support for localgit repos created before renaming from master to main.
detect_main_branch()
{
    if git show-ref --verify --quiet refs/heads/master; then
        echo "master"
    elif git show-ref --verify --quiet refs/heads/main; then
        echo "main"
    else
        error "can not find main nor master branch"
    fi
}

expect_topic()
{
    if [[ "$(current_branch)" == "$main_branch" ]]; then
        error "should be in topic branch but in main"
    fi
}

expect_main()
{
    if [[ "$(current_branch)" != "$main_branch" ]]; then
        error "should be in main branch but in $(current_branch)"
    fi
}

current_branch()
{
    git rev-parse --abbrev-ref HEAD
}

# Print all files in repo.
all_files()
{
    git ls-tree --full-tree -r "$main_branch" | awk '{print $4}' | grep -vw .lg
}

# Wrapper around git rebase that tolerates .git/rebase-merge cleanup failures
# on NFS.  If the rebase itself succeeded (git prints "Successfully rebased")
# but the exit code is non-zero, manually remove the leftover directory.
git_rebase()
{
    local output
    local rc=0
    output=$(git rebase "$@" 2>&1) || rc=$?
    echo "$output"
    if (( rc != 0 )); then
        if echo "$output" | grep -q "Successfully rebased"; then
            rm -rf "$(git rev-parse --git-dir)/rebase-merge"
        else
            return $rc
        fi
    fi
}

# Print root of git repo.
git_root() {
    git rev-parse --show-toplevel
}

start_non_local_git_root_creation()
{
    local -r name="$1"

    if [[ -n "$LG_GIT_DIR_PREFIX" ]]; then
        [[ -d "$LG_GIT_DIR_PREFIX" ]] || error "directory not found: $LG_GIT_DIR_PREFIX"
        local -r git_dir="$LG_GIT_DIR_PREFIX/${name}.git"
        [[ ! -d "$git_dir" ]] || error "directory already exists: $git_dir"
        pushd "$LG_GIT_DIR_PREFIX"
    fi
}

# macOS does not have realpath(1) so emulate it.
# Pinched from https://stackoverflow.com/questions/3572030/bash-script-absolute-path-with-os-x
portable_realpath()
{
    local -r path="$1"

    local -r saved_cwd="$(pwd)"

    cd "$(dirname "$path")"
    local link
    link=$(readlink "$(basename "$path")")
    while [[ -n "$link" ]]; do
        cd "$(dirname "$link")"
        link=$(readlink "$(basename "$link")")
    done
    local -r real="$(pwd)/$(basename "$path")"
    cd "$saved_cwd"
    echo "$real"
}

xrealpath()
{
    local -r path="$1"

    if type realpath >/dev/null 2>&1; then
        realpath "$path"
    else
        portable_realpath "$path"
    fi
}

complete_non_local_git_root_creation()
{
    local -r name="$1"

    if [[ -n "$LG_GIT_DIR_PREFIX" ]]; then
        mv .git "${name}.git"
        popd
        local -r git_dir="$LG_GIT_DIR_PREFIX/${name}.git"
        git --git-dir "$git_dir" config core.worktree "$(pwd)"
        echo "gitdir: $(xrealpath "$git_dir")" > .git
    fi
}

parent_dir()
{
    basename "$(pwd)"
}

##############################################################################
# init command
##############################################################################

commands="${commands}init - create local git\n"

lg_init()
{
    local opt
    local name
    name="$(parent_dir)"
    while getopts ":r:n:" opt; do
        case $opt in
            n) name="$OPTARG" ;;
            :) error "option $OPTARG: missing argument" ;;
            *) error "bad option: $OPTARG" ;;
        esac
    done

    shift $(( OPTIND - 1 ))

    [[ ! -r .git ]] || error ".git already exists"

    start_non_local_git_root_creation "$name"

    tron

    git init --initial-branch=main

    # Create dummy initial commit.
    # Failing this initial lg-import from orphan topic branch fails.
    git commit --allow-empty -m 'lg: big bang'

    complete_non_local_git_root_creation "$name"

    # Switch to topic branch.
    git checkout -b dev
}

##############################################################################
# import command
##############################################################################

commands="${commands}import - add file to local git\n"

lg_import()
{
    local rebase_all=0
    local opt
    while getopts ":ra" opt; do
        case $opt in
            a) rebase_all=1 ;;
            :) error "option $OPTARG: missing argument" ;;
            *) error "bad option: $OPTARG" ;;
        esac
    done
    
    shift $(( OPTIND - 1 ))
    
    # Error out if some files do not exist or are already baselined.
    local f
    for f in "$@"; do
        [[ -f "$f" ]] || error "missing file: $f"
        if all_files | grep -q -w "$f"; then
            error "file already baselined: $f"
        fi
        if git ls-files "$f" | grep -q .; then
            error "file already committed on topic branch: $f"
        fi
    done

    # Error out if some files are not descendants of the repo root.
    local -r root_pattern="$(git_root)/*"
    for f in "$@"; do
        # Intentionally not quoting variables on next line to trigger pattern matching.
        # shellcheck disable=SC2053
        if [[ $(xrealpath "$f") != $root_pattern ]]; then
            error "file not under repo root: $f"
        fi
    done

    expect_topic

    local -r topic=$(current_branch)

    local log="lg: import $*"

    # If commit log too long to fit in 80 columns, first strip directories.
    if (( ${#log} > (80 - 3) )); then
        log="lg: import"
        for f in "$@"; do
            log="$log $(basename "$f")"
        done
    fi

    # If log still too long, truncate it.
    if (( ${#log} > (80 - 3) )); then
        log="${log:0:76}..."
    fi

    tron

    local must_unstash
    must_unstash=0
    if ! git diff-index --quiet HEAD; then
        git stash push -m "lg-import: $*"
        must_unstash=1
    fi

    git checkout "$main_branch"

    git add -f "$@"

    # TODO: Sometimes the detection of files already baselined fails because
    # it is flawed: it greps a sequence of repo-relative paths against an
    # arbitrary path that may for example contain '..'.
    # Work around this for the time being by absorbing the "nothing to commit"
    # error to avoid bailing out while in main.
    local commit_output
    local commit_rc=0
    commit_output=$(git commit -m "$log" 2>&1) || commit_rc=$?
    if (( commit_rc != 0 )); then
        if ! echo "$commit_output" | grep -q "nothing to commit"; then
            echo "$commit_output" >&2
            return $commit_rc
        fi
    fi

    if (( rebase_all )); then
        while IFS= read -r branch; do
            echo "Rebasing branch: $branch"
            git checkout "$branch"
            git_rebase "$main_branch"
        done < <(git for-each-ref --format='%(refname:short)' refs/heads/ | grep -v "^${main_branch}$")

        git checkout "$topic"
    else
        git checkout "$topic"
        git_rebase "$main_branch"
    fi

    if (( must_unstash )); then
        git stash pop --index
    fi
}

##############################################################################
# sync command
##############################################################################

commands="${commands}sync - rebase local main branch after sync'ing from remote SCM\n"

lg_sync()
{
    expect_main

    local msg="lg: sync"
    if [[ -n "$*" ]]; then
        msg="$msg: $*"
    fi

    tron

    pushd "$(git_root)"
    # shellcheck disable=SC2046
    git add $(all_files)
    popd

    git commit -m "$msg"
}

##############################################################################
# status command
##############################################################################

commands="${commands}status - print status of files in local branches\n"

lg_status()
{
    git status -uno
}

##############################################################################
# log command
##############################################################################

commands="${commands}log - run git log on local topic branch excluding local main\n"

lg_log()
{
    expect_topic
    git log "$main_branch..$*"
}

##############################################################################
# files command
##############################################################################

commands="${commands}files - print files in local topic branch\n"

lg_files()
{
    expect_topic
    local rev="$*"
    if [[ -z "$rev" ]]; then
        rev="$main_branch...HEAD"
    fi

    git diff "$rev" | awk '
        function flush(action) { if (file != "") { print action, file; file = "" } }
        /^diff/ { flush("edit"); file = substr($3, 3) }
        /^new file/ { flush("add") }
        /^deleted file/ { flush("delete") }
        END { flush("edit") }
        '
}

##############################################################################
# clone command
##############################################################################

commands="${commands}clone - clone local git repo into another existing source tree\n"

# Validate user-provided source git directory and follow link if .git file provided.
src_git_dir()
{
    local src="$1"
    [[ -n "$src" ]] || error "missing source repo"
    if [[ -f "$src" ]]; then
        local -r remote_dir="$(awk '/^gitdir:/ { print $2 }' "$src")"
        [[ -n "$remote_dir" ]] || error "no gitdir in $src file"
        src="$remote_dir"
    fi
    [[ -d "$src" ]] || error "source git repo does not exist: $src"
    echo "$src"
}

lg_clone()
{
    local opt
    local name
    name="$(parent_dir)"
    while getopts ":n:" opt; do
        case $opt in
            n) name="$OPTARG" ;;
            :) error "option $OPTARG: missing argument" ;;
            *) error "bad option: $OPTARG" ;;
        esac
    done

    shift $(( OPTIND - 1 ))

    local -r src="$(src_git_dir "$1")"

    start_non_local_git_root_creation "$name"

    tron

    git init --initial-branch="main"

    complete_non_local_git_root_creation "$name"

    git remote add origin "$src"
    git fetch

    # Sync local main branch with remote one leaving local changes unmodified.
    git reset "origin/main"
}

##############################################################################
# apply command
##############################################################################

commands="${commands}apply - apply a patch, importing files as needed\n"

lg_apply()
{
    expect_topic

    (( $# > 0 )) || error "usage: apply [git-apply-options...] <patch-file>"

    # Last argument is the patch file; everything else is forwarded to git apply.
    local -r patch="${!#}"
    local -a apply_opts=("${@:1:$#-1}")

    [[ -f "$patch" ]] || error "patch file not found: $patch"

    # Resolve patch path to absolute before changing to repo root, so that
    # relative paths still work.
    local -r abs_patch="$(xrealpath "$patch")"

    # Work from the repo root so that repo-relative paths parsed from the
    # patch resolve correctly even when invoked from a subdirectory.
    cd "$(git_root)"

    # Parse patch to determine which files need importing.
    local -a files_to_import=()
    local file="" kind=""

    # If current file needs importing, add it to files_to_import.
    flush_file_entry()
    {
        if [[ -n "$file" && "$kind" != "new" ]]; then
            if ! all_files | grep -qw "$file"; then
                [[ -f "$file" ]] || error "file not found in workspace: $file"
                files_to_import+=("$file")
            fi
        fi
    }

    while IFS= read -r line; do
        case "$line" in
            "diff --git "*)
                flush_file_entry
                file="${line#diff --git a/}"
                file="${file%% b/*}"
                kind="edit"
                ;;
            "new file mode"*)
                kind="new"
                ;;
            "deleted file mode"*)
                kind="delete"
                ;;
            "rename from "*)
                file="${line#rename from }"
                kind="rename"
                ;;
        esac
    done < "$abs_patch"

    flush_file_entry

    # De-duplicate.
    local -a unique_files=()
    if (( ${#files_to_import[@]} > 0 )); then
        while IFS= read -r f; do
            unique_files+=("$f")
        done < <(printf '%s\n' "${files_to_import[@]}" | sort -u)
    fi

    # Import files that are not yet tracked.
    if (( ${#unique_files[@]} > 0 )); then
        lg_import "${unique_files[@]}"
    fi

    # Apply the patch.
    git apply "${apply_opts[@]}" "$abs_patch"
}

##############################################################################
# p4 command and subcommands
##############################################################################

# LG_P4_CMD is used to mock p4 binary for testing.
p4_cmd="${LG_P4_CMD:-p4}"

p4_root()
{
    type "$p4_cmd" >/dev/null 2>&1 || error "cannot find p4 executable in path"

    local root
    root="$($p4_cmd info | sed -n 's/^Client root: //p')"
    [[ -n "$root" ]] || error "cannot find p4 client root"

    echo "$root"
}

emit_p4_export_commands()
{
    expect_topic

    git diff --find-renames "$main_branch..HEAD" | awk '
        function flush() { if (from != "") { print "edit", from; from = to = "" } }
        /^diff/ { flush(); from = substr($3, 3); to = substr($4, 3) }
        /^new file/ { print("add", from); from = to = "" }
        /^deleted file/ { print("delete", from); from = to = "" }
        /^rename from/ { print("edit", from); print("move", from, to); from = to = "" }
        END { flush() }
        '
}

escape_p4_path()
{
    sed 's/@/%40/'
}

commands="${commands}p4 export - reflect all changes in topic branch into default changelist\n"

lg_p4_export()
{
    pushd "$(p4_root)"

    local opt
    revert=0
    while getopts ":r" opt; do
        case $opt in
            r) revert=1 ;;
            :) error "option $OPTARG: missing argument" ;;
            *) error "bad option: $OPTARG" ;;
        esac
    done
    shift $(( OPTIND - 1 ))

    # If requested, reset perforce state but keep all files as-is on disk.
    # This way this command can be run several times without weird effects.
    if (( revert )); then
        $p4_cmd revert -k ...
    fi

    # Accumulate failed commands into temporary file.
    local failed_commands
    failed_commands="$(mktemp)" || error "cannot create temporary file"
    # We want to expand now rather than at exit-time as exit could be called from caller.
    # shellcheck disable=SC2064
    trap "rm -f '$failed_commands'" EXIT

    emit_p4_export_commands | escape_p4_path | while read -r cmd
    do
        # Do not error out as some errors are harmless.
        # When calling repeatedly this command and some files were moved, the corresponding
        # p4 commands fail after the first time because the sources do not exist anymore.
        set +e
        # Intentionally not quoting variable on next line to pass several arguments to p4.
        # shellcheck disable=SC2086
        if ! $p4_cmd $cmd; then
            echo "$p4_cmd $cmd" >> "$failed_commands"
        fi
        set -e
    done

    if [[ -s "$failed_commands" ]]; then
        echo 1>&2 "WARNING: some p4 commands failed:"
        cat 1>&2 "$failed_commands"
        exit 1
    fi

    popd
}

commands="${commands}p4 dry-export - display p4 commands that would be executed by p4 export\n"

lg_p4_dry_export()
{
    emit_p4_export_commands | while read -r cmd
    do
        # Intentionally not quoting variable on next line to pass several arguments to p4.
        # shellcheck disable=SC2086
        echo p4 $cmd
    done
}

lg_p4()
{
    local -r subcmd="$1"
    case "$subcmd" in
        dry-export)
            shift 1
            lg_p4_dry_export "$@" ;;
        export)
            shift 1
            lg_p4_export "$@" ;;
        *)
            error "unknown or missing subcommand" ;;
    esac
}

##############################################################################
# MAIN PROGRAM
##############################################################################

(( $# > 0 )) || usage "missing command"

cmd=$1
shift

case "$cmd" in
    init|help|clone)
        # For commands that do not assume an existing repo, force main branch
        # name.
        main_branch="main" ;;
    *)
        # For other commands use existing main branch name.
        main_branch=$(detect_main_branch) ;;
esac

case "$cmd" in
    init)       lg_init "$@" ;;
    i|import)   lg_import "$@" ;;
    sync)       lg_sync "$@" ;;
    s|status)   lg_status "$@" ;;
    f|files)    lg_files "$@" ;;
    log)        lg_log "$@" ;;
    clone)      lg_clone "$@" ;;
    a|apply)    lg_apply "$@" ;;
    p4)         lg_p4 "$@" ;;
    help)       usage ;;
    *)          usage "unknown command: $cmd" ;;
esac
