# Create a mock p4 script that logs commands to a file.
# Sets LG_P4_CMD, P4_MOCK_CLIENT_ROOT and P4_MOCK_LOG for use in tests.
setup_mock_p4()
{
    local -r mock_dir="$(pwd)/mock_p4_bin"
    mkdir "$mock_dir"
    P4_MOCK_LOG="$(pwd)/p4_calls.log"
    true > "$P4_MOCK_LOG"
    export P4_MOCK_LOG

    cat > "$mock_dir/fake_p4" <<'MOCK'
#!/bin/bash
echo "$@" >> "$P4_MOCK_LOG"
if [[ "$1" == "info" ]]; then
    # p4_root() extracts "Client root:" from "p4 info" output, then
    # lg_p4_export() pushd's into it.  P4_MOCK_CLIENT_ROOT lets the test
    # control that directory so the pushd succeeds.
    echo "Client root: $P4_MOCK_CLIENT_ROOT"
elif [[ "$1" == "have" ]]; then
    if [[ -n "$P4_MOCK_HAVE_OUTPUT" && -f "$P4_MOCK_HAVE_OUTPUT" ]]; then
        cat "$P4_MOCK_HAVE_OUTPUT"
    fi
fi
MOCK
    chmod +x "$mock_dir/fake_p4"
    export LG_P4_CMD="$mock_dir/fake_p4"
    export P4_MOCK_CLIENT_ROOT="$(pwd)"
}

teardown_mock_p4()
{
    unset LG_P4_CMD P4_MOCK_CLIENT_ROOT P4_MOCK_LOG P4_MOCK_HAVE_OUTPUT
}

write_mock_p4_have()
{
    P4_MOCK_HAVE_OUTPUT="$(pwd)/p4_have.out"
    export P4_MOCK_HAVE_OUTPUT
    local n=1
    for f in "$@"; do
        echo "//depot/mock/path#$n - $f" >> "$P4_MOCK_HAVE_OUTPUT"
        n=$((n + 1))
    done
}

