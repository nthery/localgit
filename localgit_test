test_lg_apply_edit_not_yet_imported()
{
    # Create a file and initialize localgit but do NOT import the file.
    echo AAA > a
    lg init

    # Generate a patch that edits the file (need a temp repo to produce the diff).
    mkdir ../patch_src1
    pushd ../patch_src1
    git init --initial-branch=main
    echo AAA > a
    git add a && git commit -m 'baseline'
    echo BBB >> a
    git diff > ../the.patch
    git checkout -- a
    popd

    local -r main_before=$(git rev-parse main)

    # Apply the patch via lg apply.
    lg apply ../the.patch

    # The file should have been imported into main.
    assert "all_files_in_main | grep -qw a"

    # The import should have added a commit on main.
    assert '[[ "$(git rev-parse main)" != "$main_before" ]]'
    assert 'git log --oneline main | grep -q "lg: import a"'

    # The topic branch should be rebased on top of the new main.
    assert 'git merge-base --is-ancestor main HEAD'

    # The patch should have been applied on the topic branch.
    assert "grep -q BBB a"
}

test_lg_apply_new_file()
{
    lg init

    # Generate a patch that adds a brand-new file.
    mkdir ../patch_src2
    pushd ../patch_src2
    git init --initial-branch=main
    git commit --allow-empty -m 'baseline'
    echo NEW > b
    git add b
    git diff --cached > ../the.patch
    popd

    # Record main branch tip before apply.
    local -r main_before=$(git rev-parse main)

    lg apply ../the.patch

    # main should be unchanged (no import for new files).
    assert '[[ "$(git rev-parse main)" == "$main_before" ]]'

    # The new file should exist in the working tree.
    assert "[[ -f b ]]"
    assert "grep -q NEW b"
}

test_lg_apply_rename()
{
    echo AAA > a
    lg init

    # Generate a patch that renames a -> b (with rename detection).
    mkdir ../patch_src3
    pushd ../patch_src3
    git init --initial-branch=main
    echo AAA > a
    git add a && git commit -m 'baseline'
    git mv a b
    git diff --cached -M > ../the.patch
    popd

    local -r main_before=$(git rev-parse main)

    lg apply ../the.patch

    # The old file should have been imported into main.
    assert "all_files_in_main | grep -qw a"
    assert '[[ "$(git rev-parse main)" != "$main_before" ]]'
    assert 'git log --oneline main | grep -q "lg: import a"'
    assert 'git merge-base --is-ancestor main HEAD'

    # After applying, b should exist and a should be gone.
    assert "[[ -f b ]]"
    assert "! [[ -f a ]]"
    assert "grep -q AAA b"
}

