test_lg_apply_mixed()
{
    echo AAA > a
    echo BBB > b
    echo CCC > c
    lg init
    lg import b

    # Generate a patch that:
    # - edits a (not yet imported)
    # - edits b (already imported)
    # - adds d (new file)
    # - deletes c via rename to e (with rename detection)
    mkdir ../patch_src5
    pushd ../patch_src5
    git init --initial-branch=main
    echo AAA > a
    echo BBB > b
    echo CCC > c
    git add a b c && git commit -m 'baseline'
    echo AAA2 >> a
    echo BBB2 >> b
    git mv c e
    echo DDD > d
    git add a b d
    git diff --cached -M > ../the.patch
    popd

    local -r main_before=$(git rev-parse main)

    lg apply ../the.patch

    # a and c should have been imported into main.
    assert "all_files_in_main | grep -qw a"
    assert "all_files_in_main | grep -qw c"
    assert '[[ "$(git rev-parse main)" != "$main_before" ]]'
    assert 'git log --oneline main | grep -q "lg: import"'
    assert 'git merge-base --is-ancestor main HEAD'

    # a should have been patched.
    assert "grep -q AAA2 a"

    # b was already imported; patch applied.
    assert "grep -q BBB2 b"

    # c should have been renamed to e.
    assert "! [[ -f c ]]"
    assert "[[ -f e ]]"
    assert "grep -q CCC e"

    # d is a new file, no import needed.
    assert "[[ -f d ]]"
    assert "grep -q DDD d"
}

